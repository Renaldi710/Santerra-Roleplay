	PlayerTextDrawLetterSize(playerid, PlayerTD[playerid][169], 0.600000, 2.000000);
	PlayerTextDrawTextSize(playerid, PlayerTD[playerid][169], 32.500000, 40.500000);
	PlayerTextDrawSetOutline(playerid, PlayerTD[playerid][169], 0);
	PlayerTextDrawSetShadow(playerid, PlayerTD[playerid][169], 0);
	PlayerTextDrawAlignment(playerid, PlayerTD[playerid][169], 1);
	PlayerTextDrawColor(playerid, PlayerTD[playerid][169], -1);
	PlayerTextDrawBackgroundColor(playerid, PlayerTD[playerid][169], 0);
