	PlayerTextDrawUseBox(playerid, PlayerTD[playerid][169], 0);
	PlayerTextDrawSetProportional(playerid, PlayerTD[playerid][169], 1);
	PlayerTextDrawSetSelectable(playerid, PlayerTD[playerid][169], 1);
	PlayerTextDrawSetPreviewModel(playerid, PlayerTD[playerid][169], 19835);
	PlayerTextDrawSetPreviewRot(playerid, PlayerTD[playerid][169], -11.000000, -1.000000, -13.000000, 1.149999);
	PlayerTextDrawSetPreviewVehCol(playerid, PlayerTD[playerid][169], 1, 1);

	return 1;
}

